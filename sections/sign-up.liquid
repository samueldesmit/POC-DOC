        {
            "type": "checkbox",
            "id": "border_top",
            "label": "Add border top",
            "default": false
        },
        {
            "type": "checkbox",
            "id": "border_bottom",
            "label": "Add border bottom",
            "default": false
        },
        {
            "type": "header",
            "content": "Animation"
        },
        {
            "type": "select",
            "id": "animation_style",
