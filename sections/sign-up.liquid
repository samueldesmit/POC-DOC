                    "value": "primary",
                    "label": "Primary"
                },
                {
                    "value": "secondary",
                    "label": "Secondary"
                }
            ],
            "default": "primary"
        },
        {
            "type": "checkbox",
            "id": "grid_of_two",
            "label": "Grid of two",
