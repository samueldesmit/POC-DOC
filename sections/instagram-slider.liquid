{% liquid
    assign s = section.settings
    assign section_id = 'section-' | append: section.id

    assign show_section = true

    if s.visibility_audience == 'premium_only'
        assign show_section = false
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = true
            endif
        endif
    elsif s.visibility_audience == 'non_premium_only'
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = false
            endif
        endif
    endif
%}

{% if show_section %}
<div
    id="{{ section_id }}"
    class="{{ s.mobile_margin }} {{ s.desktop_margin }} bg-background overflow-hidden"
>
    {% render 'section-colors', current_section: section %}
    <div
        class="{{ s.mobile_padding }} {{ s.desktop_padding }} container text-primary overflow-visible"
    >
        {% if s.title != blank or s.handle != blank %}
            <div class="flex flex-col-reverse lg:flex-row items-center justify-between mb-6 lg:mb-15 gap-3">
                {% if s.title != blank %}
                    <h3 class="font-cormorant-garamond text-[30px] lg:text-[40px] font-semibold">
                        {{ s.title }}
                    </h3>
                {% endif %}

                {% if s.handle != blank %}
                    <a
                        href="{{ s.link }}"
                        {% if s.open_in_new_tab %}
                            target="_blank"
                            rel="noopener noreferrer"
                        {% endif %}
                        class="uppercase flex items-center gap-2 group"
                    >
                        {% render 'component.icon',
                            type: 'instagram',
                            class: 'w-[22px] h-[22px]'
                        %}
                        <span class="link-animation group-hover:after:origin-bottom-left group-hover:after:scale-x-100 font-inter font-normal leading-[150%] tracking-[0.05em] uppercase text-[15px] lg:text-[17px]">
                            {{ s.handle }}
                        </span>
                    </a>
                {% endif %}
            </div>
        {% endif %}
        {% liquid
            if s.autoplay != false
                assign slider_type = 'loop'
            else
                assign slider_type = 'slide'
            endif
        %}

        {% if s.animation_style != blank and s.animation_style != 'none' -%}
            <gsap-section data-animation="{{ s.animation_style }}">
        {%- endif %}
        <splide-section
            class="instagram-slider-container overflow-visible"
            data-splide-type="{{ slider_type }}"
            data-splide-per-page-desktop="{{ s.per_page_desktop }}"
            data-splide-per-page-mobile="{{ s.per_page_mobile }}"
            data-splide-autoplay="{{ s.autoplay }}"
            data-splide-interval="{{ s.interval | times: 1000 }}"
            data-splide-gap-desktop="{{ s.gap_desktop }}px"
            data-splide-gap-mobile="{{ s.gap_mobile }}px"
        >
            <div class="splide overflow-visible">
                <div class="splide__track overflow-visible!">
                    <ul class="splide__list overflow-visible">
                        {% for block in section.blocks %}
                            {% assign b = block.settings %}
                            <li class="splide__slide {{ s.aspect_ratio }}">
                                {% if b.caption != blank %}
                                    <a
                                        href="{{ b.link }}"
                                        {% if b.open_in_new_tab %}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                        {% endif %}
                                        class="{{ s.aspect_ratio }} absolute inset-0 z-10 w-full h-full text-center  flex items-center justify-center bg-black/50 text-white opacity-0 hover:opacity-100 p-5 overflow-hidden transition-opacity duration-300"
                                    >
                                        {{ b.caption }}
                                    </a>
                                {% endif %}
                                <a
                                    href="{{ b.link }}"
                                    {% if b.open_in_new_tab %}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    {% endif %}
                                    class="block w-full h-full"
                                    aria-label="{{ b.caption | default: b.image.alt | default: 'Instagram post' | escape }}"
                                >
                                    {% if b.image != blank %}
                                        <responsive-media
                                            class="{{ s.aspect_ratio }} block w-full h-full"
                                            data-visible
                                        >
                                            {{
                                                b.image
                                                | image_url: width: 1440
                                                | image_tag:
                                                    class: 'object-cover w-full h-full'
                                            -}}
                                        </responsive-media>
                                    {% else %}
                                        <div class="{{ s.aspect_ratio }}">
                                            {{
                                                'image'
                                                | placeholder_svg_tag: 'placeholder-svg w-full h-full bg-gray-100 text-white'
                                            }}
                                        </div>
                                    {% endif %}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </splide-section>
        {% if s.animation_style != blank and s.animation_style != 'none' -%}
            </gsap-section>
        {%- endif %}
    </div>
</div>
{% endif %}

{% schema %}
