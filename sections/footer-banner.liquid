{% liquid
    assign s = section.settings
    assign section_id = 'section-' | append: section.id

    assign show_section = true

    if s.visibility_audience == 'premium_only'
        assign show_section = false
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = true
            endif
        endif
    elsif s.visibility_audience == 'non_premium_only'
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = false
            endif
        endif
    endif
%}

{% if show_section %}
<div
    id="{{ section_id }}"
    class="bg-background"
>
    {% render 'section-colors', current_section: section %}

    <div class="container lg:hidden py-3">
        <p class="text-center text-[0.8125rem] text-primary">
            {{- s.text_mobile -}}
        </p>
    </div>

    <div class="container hidden lg:flex items-center justify-between">
        <p class="text-sm text-primary py-4">
            {{- s.text_desktop -}}
        </p>

        {% if s.image != blank %}
            <div class="flex-shrink-0">
                {{-
                    s.image
                    | image_url: width: 800
                    | image_tag:
                        class: 'max-w-25 h-auto aspect-[100/27] object-cover',
                        loading: 'lazy'
                -}}
            </div>
        {% endif %}
    </div>
</div>
{% endif %}

{% schema %}
{
    "name": "Footer Banner",
    "tag": "section",
    "class": "footer-banner",
    "settings": [
        {
            "type": "header",
            "content": "Visibility"
        },
        {
            "type": "select",
            "id": "visibility_audience",
            "label": "Visibility (audience)",
            "options": [
                {
                    "value": "everyone",
                    "label": "Everyone"
                },
                {
                    "value": "premium_only",
                    "label": "Only premium-club customers"
                },
                {
                    "value": "non_premium_only",
                    "label": "Only non premium-club customers"
                }
            ],
            "default": "everyone"
        },
        {
            "type": "header",
            "content": "Documentation for this section",
            "info": "Click [here](https://strix-net.atlassian.net/wiki/spaces/TWL/pages/4045701133/Footer+banner) for more information."
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "text",
            "id": "text_desktop",
            "label": "Text (Desktop)",
            "default": "Copyright © 2021 The Vintage 3.0 BV"
        },
        {
            "type": "text",
            "id": "text_mobile",
            "label": "Text (Mobile)",
            "default": "Copyright © 2021 The Vintage 3.0 BV"
        },
        {
            "type": "header",
            "content": "Image"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image (Desktop only - right side)",
            "info": "Image will only be visible on desktop on the right side. Aspect ratio: 100:27"
        },
        {
            "type": "header",
            "content": "Section Styling"
        },
        {
            "type": "checkbox",
            "id": "section_styling",
            "label": "Add styling to section",
            "info": "If enabled this shows the settings to set the color scheme, spacing, and margin for the section.",
            "default": false
        },
        {
            "type": "header",
            "content": "Colors",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "background",
            "label": "Section background color",
            "default": "#B19E5E",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "primary_text_color",
            "label": "Primary text color",
            "default": "#FFFFFF",
            "visible_if": "{{ section.settings.section_styling == true }}"
        }
    ],
    "enabled_on": {
        "groups": ["footer"]
    },
    "presets": [
        {
            "name": "Footer Banner",
            "settings": {
                "text_desktop": "Copyright © 2021 The Vintage 3.0 BV",
                "text_mobile": "Copyright © 2021 The Vintage 3.0 BV"
            }
        }
    ]
}
{% endschema %}
