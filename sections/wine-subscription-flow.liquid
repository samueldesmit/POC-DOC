{% liquid
    assign s = section.settings
    assign section_id = 'section-' | append: section.id

    assign show_section = true

    if s.visibility_audience == 'premium_only'
        assign show_section = false
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = true
            endif
        endif
    elsif s.visibility_audience == 'non_premium_only'
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = false
            endif
        endif
    endif
%}

{% if show_section %}
<div
    class="{{ s.mobile_margin }} {{ s.desktop_margin }} bg-background"
    id="{{ section_id }}"
>
    {% render 'section-colors', current_section: section %}
    <div class="{{ s.mobile_padding }} {{ s.desktop_padding }} container">
        <wine-subscription-flow
            data-draft-order-tag="{{ s.draft_order_tag | default: 'subscription' }}"
            data-login-url="{{ routes.storefront_login_url }}"
            {% if customer %}
                data-customer-id="{{ customer.id }}"
            {% endif %}
        >
            {%- comment -%} Step Indicator {%- endcomment -%}
            {% capture step_circle_classes %}step-circle min-w-[34px] h-[34px] lg:min-w-10 lg:h-10 rounded-full flex items-center justify-center font-cormorant-garamond text-[24px] lg:text-[30px] leading-none text-white bg-secondary/50 relative cursor-pointer transition-all duration-300 hover:scale-105 [&.active]:bg-secondary{% endcapture %}
            {% capture step_line_classes %}step-line w-[35px] lg:w-20 h-0.5 bg-secondary/50 transition-colors duration-300 [&.active]:bg-secondary{% endcapture %}
            {% capture side_line_classes %}w-[490px] h-px bg-secondary/50 hidden lg:block{% endcapture %}

            <div class="flex items-center justify-center gap-3 mb-8 lg:mb-12">
                <div class="{{ side_line_classes }}"></div>

                <button
                    type="button"
                    class="{{ step_circle_classes }} active"
                    data-step-nav="0"
                    aria-label="Step 1: Select wines"
                >
                    <span class="mb-1 lg:mb-2">1</span>
                </button>
                <div
                    class="{{ step_line_classes }}"
                    data-line="0"
                ></div>

                <button
                    type="button"
                    class="{{ step_circle_classes }}"
                    data-step-nav="1"
                    aria-label="Step 2: Login or register"
                >
                    <span class="mb-1 lg:mb-2">2</span>
                </button>
                <div
                    class="{{ step_line_classes }}"
                    data-line="1"
                ></div>

                <button
                    type="button"
                    class="{{ step_circle_classes }}"
                    data-step-nav="2"
                    aria-label="Step 3: Confirm subscription"
                >
                    <span class="mb-1 lg:mb-3">3</span>
                </button>

                <div class="{{ side_line_classes }}"></div>
            </div>

            {%- comment -%} Step Content via Splide {%- endcomment -%}
            {%- comment -%} Hide splide instantly if restoring to a later step to prevent flash of step 1 {%- endcomment -%}
            <script>
                try {
                    var _ws = JSON.parse(
                        localStorage.getItem('wine-subscription-state'),
                    );
                    if (
                        _ws &&
                        _ws.currentStep > 0 &&
                        Date.now() - _ws.timestamp < 86400000
                    ) {
                        document.write(
                            '<style>[data-subscription-splide]{opacity:0}</style>',
                        );
                    }
                } catch (e) {}
            </script>
            <splide-section
                data-subscription-splide
                data-splide-per-page-mobile="1"
                data-splide-per-page-desktop="1"
                data-splide-gap-mobile="2rem"
                data-splide-gap-desktop="2rem"
                data-splide-keyboard="false"
                data-splide-drag="false"
                data-splide-wheel="false"
                data-splide-type="fade"
                data-splide-speed="450"
            >
                <div class="splide">
                    <div class="splide__track">
                        <ul class="splide__list">
                            {%- comment -%} Step 1: Wine Selection {%- endcomment -%}
                            {% render 'wine-subscription-step-1',
                                s: s,
                                subscription: s.subscription
                            %}
                            {%- comment -%} Step 2: Login/Register {%- endcomment -%}
                            {% render 'wine-subscription-step-2', s: s %}
                            {%- comment -%} Step 3: Confirmation {%- endcomment -%}
                            {% render 'wine-subscription-step-3', s: s %}
                        </ul>
                    </div>
                </div>
            </splide-section>
        </wine-subscription-flow>
    </div>
</div>

<style>
    /* Drive opacity from is-active so backward fade transitions can't get stuck
       with inverted inline opacity from Splide. */
    wine-subscription-flow .splide__slide {
        transition: opacity 300ms ease;
    }
    wine-subscription-flow .splide__slide:not(.is-active) {
        pointer-events: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
    }
    wine-subscription-flow .splide__slide.is-active {
        pointer-events: auto !important;
        visibility: visible !important;
        opacity: 1 !important;
    }
</style>
{% endif %}

