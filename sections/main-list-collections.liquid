{%- liquid
    assign s = section.settings
-%}

<div
    id="section-{{ section.id }}"
    class="{{ s.mobile_margin }} {{ s.desktop_margin }} bg-background"
>
    {% render 'section-colors', current_section: section %}
    <div class="{{ s.mobile_padding }} {{ s.desktop_padding }}">
        <div class="container">
            {% if s.title != blank %}
                <div class="mb-8 lg:mb-12">
                    {% render 'component.heading',
                        tag: 'h1',
                        variant: 'xl',
                        class: 'font-cormorant-garamond text-primary text-center',
                        content: s.title
                    %}
                </div>
            {% endif %}
            {%- paginate collections by s.collections_per_page -%}
                <ul
                    class="grid grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-8 lg:gap-x-6 lg:gap-y-12"
                    role="list"
                >
                    {%- for collection in collections -%}
                        <li>
                            <a
                                class="group block"
                                href="{{ collection.url }}"
                            >
                                <responsive-media class="w-full aspect-[312/360] overflow-hidden mb-4 p-4">
                                    {% if collection.image != blank %}
                                        {{
                                            collection.image
                                            | image_url: width: 800
                                            | image_tag:
                                                class: 'w-full h-full object-contain transition-transform duration-300 ease-in-out group-hover:scale-105',
                                                loading: 'lazy',
                                                widths: '312,400,624,800',
                                                sizes: '(min-width: 1024px) 33vw, 50vw'
                                        -}}
                                    {% else %}
                                        <div class="w-full h-full flex items-center justify-center">
                                            {{
                                                'collection-1'
                                                | placeholder_svg_tag: 'placeholder-svg w-full h-full bg-gray-100 text-white'
                                            }}
                                        </div>
                                    {% endif %}
                                </responsive-media>
                                <h2 class="font-cormorant-garamond text-primary text-base lg:text-[20px] text-center">
                                    {{ collection.title }}
                                </h2>
                            </a>
                        </li>
                    {%- endfor -%}
                </ul>
                {% render 'component.pagination',
                    paginate: paginate,
                    anchor: ''
                %}
            {%- endpaginate -%}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "Collection List",
    "tag": "section",
    "class": "section_collection_list",
    "settings": [
        {
            "type": "header",
            "content": "Section Styling"
        },
        {
            "type": "checkbox",
            "id": "section_styling",
            "label": "Add styling to section",
            "info": "If enabled this shows the settings to set the color scheme, spacing, and margin for the section.",
            "default": false
        },
        {
            "type": "header",
            "content": "Section Spacing",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_padding",
            "label": "Mobile padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "py-0",
                    "label": "None"
                },
                {
                    "value": "py-4",
                    "label": "M - 16px"
                },
                {
                    "value": "py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "py-12",
                    "label": "3XL - 48px"
                }
            ],
            "default": "py-8"
        },
        {
            "type": "select",
            "id": "desktop_padding",
            "label": "Desktop padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "lg:py-0",
                    "label": "None"
                },
                {
                    "value": "lg:py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "lg:py-12",
                    "label": "3XL - 48px"
                },
                {
                    "value": "lg:py-16",
                    "label": "4XL - 64px"
                }
            ],
            "default": "lg:py-16"
        },
        {
            "type": "header",
            "content": "Section Margin",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_margin",
            "label": "Mobile Section margin",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "mb-0",
                    "label": "None"
                },
                {
                    "value": "mb-4",
                    "label": "Small - 16px"
                },
                {
                    "value": "mb-8",
                    "label": "Medium - 32px"
                },
                {
                    "value": "mb-12",
                    "label": "Large - 48px"
                }
            ],
            "default": "mb-0"
        },
        {
            "type": "select",
            "id": "desktop_margin",
            "label": "Desktop Section margin",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "lg:mb-0",
                    "label": "None"
                },
                {
                    "value": "lg:mb-8",
                    "label": "Small - 32px"
                },
                {
                    "value": "lg:mb-12",
                    "label": "Medium - 48px"
                },
                {
                    "value": "lg:mb-16",
                    "label": "Large - 64px"
                }
            ],
            "default": "lg:mb-0"
        },
        {
            "type": "header",
            "content": "Colors",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "background",
            "label": "Section background color",
            "default": "#FFFFFF",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "primary_text_color",
            "label": "Primary text color",
            "default": "#000000",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "text",
            "id": "title",
            "label": "Section title",
            "default": "Onze Collecties"
        },
        {
            "type": "number",
            "id": "collections_per_page",
            "label": "Collections per page",
            "default": 12
        }
    ]
}
{% endschema %}
