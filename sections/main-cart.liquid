<cart-form
    class="group/cart-form relative"
    data-section-id="{{ section.id }}"
>
    <div class="container py-8 lg:py-12 xl:pb-16">
        <h1 class="mb-8 font-cormorant-garamond text-[1.75rem] font-medium leading-[130%] text-surface-500">
            {{- 'cart.main-cart.title' | t -}}
        </h1>

        <footer
            class="mb-5 lg:hidden"
            data-target="cart-form.footer"
        >
            {%- if cart.item_count > 0 %}
                <div class="flex flex-col gap-4 bg-surface-200/10 p-5">
                    <span class="flex w-full justify-between">
                        <p class="text-[0.9375rem] font-normal text-surface-500">
                            {{ 'cart.main-cart.order_total' | t }}
                        </p>
                        <p class="text-[0.9375rem] font-medium text-surface-500">
                            {{- cart.total_price | money -}}
                        </p>
                    </span>

                    <form
                        action="{{ routes.cart_url }}"
                        aria-label="Checkout form"
                        method="post"
                        class="group-data-[loading]/cart-form:pointer-events-none ml-auto grid w-full gap-2"
                    >
                        {%- liquid
                            assign checkout_button_label = 'cart.main-cart.checkout' | t
                        -%}
                        {%- render 'component.button',
                            type: 'submit',
                            name: 'checkout',
                            label: checkout_button_label,
                            style: 'primary',
                            size: 'medium',
                            class: 'w-full justify-center'
                        -%}
                    </form>
                </div>
            {% endif -%}
        </footer>

        <div class="flex flex-col gap-10 lg:gap-12 xl:flex-row">
            <div class="w-full flex-1">
                <cart-items class="relative block">
                    {%- if cart.item_count > 0 -%}
                        <div class="mb-4 hidden w-full border-b border-surface-200/30 pb-3 lg:grid lg:grid-cols-[1fr_3fr_5fr] lg:gap-4">
                            <span class="font-inter text-[0.6875rem] font-normal uppercase tracking-[0.034375rem] text-surface-500">
                                {{- 'cart.main-cart.product' | t -}}
                            </span>
                            <span class="min-w-[13rem]"></span>
                            <div class="flex justify-between px-4">
                                <span class="mr-2 w-[7rem] font-inter text-[0.6875rem] font-normal uppercase tracking-[0.034375rem] text-surface-500">
                                    {{- 'cart.main-cart.quantity' | t -}}
                                </span>
                                <span class="mr-2 min-w-[5rem] font-inter text-[0.6875rem] font-normal uppercase tracking-[0.034375rem] text-surface-500">
                                    {{- 'cart.main-cart.price' | t -}}
                                </span>
                                <span class="min-w-[5rem] font-inter text-[0.6875rem] font-normal uppercase tracking-[0.034375rem] text-surface-500">
                                    {{- 'cart.main-cart.total' | t -}}
                                </span>
                                <span class="w-4"></span>
                            </div>
                        </div>

                        <div class="divide-y divide-surface-200/30 border-b border-t border-surface-200/30 lg:border-t-0">
                            {%- for item in cart.items %}
                                <cart-item
                                    data-key="{{ item.key }}"
                                    data-index="{{ forloop.index }}"
                                    data-target="cart-items.item"
                                    class="block py-4 transition-colors duration-300 ease-out data-[loading]:bg-surface-100"
                                >
                                    <article class="flex h-full w-full">
                                        <div class="grid w-full grid-cols-[1fr_2fr] lg:grid-cols-[1fr_3fr_5fr] lg:min-h-[6rem] h-[fit]">
                                            <a
                                                href="{{ item.product.url }}"
                                                class="overflow-hidden lg:min-w-[6rem]"
                                            >
                                                <responsive-media
                                                    class="aspect-square size-full before:bg-transparent"
                                                    data-visible
                                                >
                                                    {{
                                                        item.image
                                                        | image_url: width: 200
                                                        | image_tag:
                                                            class: 'object-contain mix-blend-multiply',
                                                            loading: 'lazy'
                                                    -}}
                                                </responsive-media>
                                            </a>

                                            <div class="hidden w-full min-w-[13rem] flex-col p-4 pb-1 text-base font-medium lg:flex">
                                                <span class="font-inter text-[0.75rem] font-normal uppercase leading-[130%] tracking-[0.034375rem] text-surface-500">
                                                    {{- item.product.vendor -}}
                                                </span>
                                                <a
                                                    href="{{ item.product.url }}"
                                                    class="font-cormorant-garamond text-[1.25rem] font-medium leading-[1.4] text-surface-500"
                                                >
                                                    {{- item.product.title -}}
                                                </a>
                                                {%- unless item.product.has_only_default_variant -%}
                                                    <span class="text-[0.75rem] text-surface-500">
                                                        {{- item.variant.title -}}
                                                    </span>
                                                {%- endunless -%}
                                            </div>

                                            <cart-item-form class="h-full w-full overflow-hidden p-3 lg:p-4">
                                                <form
                                                    action="{{ routes.cart_url }}"
                                                    data-target="cart-item.form"
                                                    class="group-data-[loading]/cart-form:pointer-events-none h-full"
                                                >
                                                    <quantity-input class="relative flex h-full flex-col justify-between gap-3">
                                                        <div class="flex w-full items-start justify-between gap-2">
                                                            <div class="flex flex-col lg:hidden">
                                                                <span class="font-inter text-[0.75rem] font-normal uppercase leading-[130%] tracking-[0.034375rem] text-surface-500">
                                                                    {{- item.product.vendor -}}
                                                                </span>
                                                                <a
                                                                    href="{{ item.product.url }}"
                                                                    class="font-cormorant-garamond text-[1.25rem] font-medium leading-[1.4] text-surface-500"
                                                                >
                                                                    {{- item.product.title -}}
                                                                </a>
                                                                {%- unless item.product.has_only_default_variant -%}
                                                                    <span class="text-[0.75rem] text-surface-500">
                                                                        {{- item.variant.title -}}
                                                                    </span>
                                                                {%- endunless -%}
                                                            </div>
                                                        </div>

                                                        <div class="flex h-full items-center justify-between gap-2 lg:gap-4 lg:px-4">
                                                            <div class="flex items-center justify-between lg:mr-2 lg:w-[7rem]">
                                                                <div class="flex min-w-[6rem] border border-black lg:min-w-[7rem]">
                                                                    <button
                                                                        data-target="quantity-input.minus"
                                                                        type="button"
                                                                        name="minus"
                                                                        aria-label="Decrease quantity"
                                                                        {% if item.variant.quantity_rule.min
                                                                            and item.quantity
                                                                                <= item.variant.quantity_rule.min
                                                                        %}
                                                                            disabled
                                                                        {% endif %}
                                                                        class="inline-flex aspect-square cursor-pointer items-center justify-center p-2 align-middle disabled:cursor-not-allowed disabled:opacity-30"
                                                                    >
                                                                        {%- render 'component.icon',
                                                                            type: 'minus',
                                                                            class: 'size-5 text-surface-500'
                                                                        -%}
                                                                    </button>
                                                                    <input
                                                                        data-target="quantity-input.input"
                                                                        class="peer inline-flex w-full items-center justify-center bg-transparent text-center align-middle text-[0.9375rem] font-normal leading-[130%] text-surface-500 outline-none focus:ring-0 focus:ring-transparent [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
                                                                        type="number"
                                                                        name="quantity-{{ item.index | plus: 1 }}"
                                                                        value="{{ item.quantity }}"
                                                                        min="{{ item.variant.quantity_rule.min | default: 1 }}"
                                                                        {% if item.variant.inventory_policy
                                                                                == 'deny'
                                                                        %}
                                                                            max="{{ item.variant.inventory_quantity }}"
                                                                        {% elsif item.variant.quantity_rule.max
                                                                                != null
                                                                        %}
                                                                            max="{{ item.variant.quantity_rule.max }}"
                                                                        {% endif %}
                                                                        step="{{ item.variant.quantity_rule.increment | default: 1 }}"
                                                                        id="Quantity-{{ item.index | plus: 1 }}"
                                                                        data-index="{{ item.index | plus: 1 }}"
                                                                    >
                                                                    <button
                                                                        data-target="quantity-input.plus"
                                                                        type="button"
                                                                        name="plus"
                                                                        aria-label="Increase quantity"
                                                                        {% if item.variant.quantity_rule.max
                                                                            and item.quantity
                                                                                >= item.variant.quantity_rule.max
                                                                        %}
                                                                            disabled
                                                                        {% elsif item.quantity
                                                                                >= item.variant.inventory_quantity
                                                                            and item.variant.inventory_policy
                                                                                == 'deny'
                                                                        %}
                                                                            disabled
                                                                        {% endif %}
                                                                        class="inline-flex aspect-square cursor-pointer items-center justify-center p-2 align-middle disabled:cursor-not-allowed disabled:opacity-30"
                                                                    >
                                                                        {%- render 'component.icon',
                                                                            type: 'plus',
                                                                            class: 'size-5 text-surface-500'
                                                                        -%}
                                                                    </button>
                                                                </div>
                                                            </div>

                                                            <div class="hidden min-w-[5rem] flex-col lg:mr-2 lg:flex">
                                                                <span class="text-[0.9375rem] font-medium leading-[130%] text-surface-500">
                                                                    {{
                                                                        item.variant.price
                                                                        | money
                                                                    }}
                                                                </span>
                                                                {%- if item.variant.compare_at_price
                                                                        > item.variant.price
                                                                -%}
                                                                    <span class="font-inter text-[0.75rem] font-normal uppercase leading-[150%] tracking-[0.6px] text-surface-400 line-through">
                                                                        {{
                                                                            item.variant.compare_at_price
                                                                            | money
                                                                        }}
                                                                    </span>
                                                                {%- endif -%}
                                                            </div>

                                                            <div class="flex min-w-[5rem] flex-col items-end justify-end gap-0 text-xs lg:min-w-[5rem] lg:items-start lg:gap-0 lg:text-base">
                                                                <span class="font-inter text-[0.75rem] font-semibold uppercase leading-[150%] tracking-[0.6px] text-brand-50 lg:text-[0.9375rem] lg:font-medium lg:normal-case lg:leading-[130%] lg:tracking-normal lg:text-surface-500">
                                                                    {{
                                                                        item.final_line_price
                                                                        | money
                                                                    }}
                                                                </span>
                                                                {%- if item.variant.compare_at_price
                                                                        > item.variant.price
                                                                -%}
                                                                    {%- assign compare_at_line_price = item.variant.compare_at_price
                                                                        | times: item.quantity
                                                                    -%}
                                                                    <span class="font-inter text-[0.75rem] font-normal uppercase leading-[150%] tracking-[0.6px] text-surface-400 line-through">
                                                                        {{
                                                                            compare_at_line_price
                                                                            | money
                                                                        }}
                                                                    </span>
                                                                {%- elsif item.original_line_price
                                                                        > item.final_line_price
                                                                -%}
                                                                    <span class="font-inter text-[0.75rem] font-normal uppercase leading-[150%] tracking-[0.6px] text-surface-400 line-through">
                                                                        {{
                                                                            item.original_line_price
                                                                            | money
                                                                        }}
                                                                    </span>
                                                                {%- endif -%}
                                                            </div>

                                                            <button
                                                                type="button"
                                                                name="remove"
                                                                aria-label="Remove item"
                                                                class="absolute right-0 top-[-0.25rem] w-fit cursor-pointer p-1 text-surface-500 transition-colors hover:text-surface-500/70 lg:relative lg:top-0 lg:w-4"
                                                                data-target="quantity-input.remove"
                                                                data-index="{{ forloop.index }}"
                                                            >
                                                                {%- render 'component.icon',
                                                                    type: 'delete_bin',
                                                                    class: 'size-4'
                                                                -%}
                                                            </button>
                                                        </div>
                                                    </quantity-input>
                                                </form>
                                            </cart-item-form>
                                        </div>
                                    </article>
                                </cart-item>
                            {% endfor -%}
                        </div>
                    {%- endif -%}

                    {%- if cart.empty? %}
                        <div
                            class="flex flex-col items-start justify-center py-16"
                            data-target="cart-items.empty"
                        >
                            <p class="mb-8 text-[0.9375rem] text-surface-500">
                                {{- 'cart.main-cart.empty' | t -}}
                            </p>
                            {% render 'component.button',
                                label: 'cart.main-cart.continue_shopping',
                                href: routes.all_products_collection_url,
                                style: 'primary',
                                size: 'medium',
                                class: 'justify-center',
                                translate: true
                            %}
                        </div>
                    {%- else -%}
                        <template data-target="cart-items.empty"></template>
                    {%- endif -%}
                </cart-items>
            </div>

            <footer
                class="flex w-full flex-col gap-2 xl:min-w-[25rem] xl:max-w-[25rem]"
                data-target="cart-form.footer"
            >
                {%- if cart.item_count > 0 -%}
                    <div class="flex flex-col bg-surface-200/10 px-5 py-6">
                        <h3 class="mb-8 font-cormorant-garamond text-[1.625rem] font-medium leading-[130%] text-surface-500">
                            {{- 'cart.main-cart.order_summary' | t -}}
                        </h3>

                        {%- if cart.item_count > 0 -%}
                            {%- if cart.requires_shipping -%}
                                <span class="mb-2 flex w-full justify-between font-inter text-[0.9375rem] font-normal leading-[130%] text-surface-500">
                                    {%- render 'cart.shipping-logic' -%}
                                </span>
                            {%- endif -%}
                        {%- endif -%}

                        <span class="mb-4 flex w-full justify-between font-inter text-sm font-medium">
                            <p class="text-[0.9375rem] font-normal leading-[130%] text-surface-500">
                                {{- 'cart.main-cart.subtotal' | t -}}
                            </p>
                            <p class="text-[0.9375rem] font-normal leading-[130%] text-surface-500">
                                {{- cart.total_price | money -}}
                            </p>
                        </span>

                        {%- if section.settings.shipping_message != blank -%}
                            <span class="mb-4 flex items-center gap-2 text-xs text-surface-500">
                                {{- section.settings.shipping_message -}}
                                {%- render 'component.icon',
                                    type: 'info_circle',
                                    class: 'size-4 shrink-0'
                                -%}
                            </span>
                        {%- endif -%}

                        {%- unless customer -%}
                            <p class="mb-4 text-xs text-surface-200">
                                <a
                                    href="{{ routes.account_login_url }}"
                                    class="font-semibold underline transition-colors hover:text-surface-500"
                                >
                                    {{- 'cart.drawer.login_link' | t -}}
                                </a>
                                {{ 'cart.drawer.login_prompt' | t }}
                            </p>
                        {%- endunless -%}

                        <form
                            action="{{ routes.cart_url }}"
                            aria-label="Checkout form"
                            method="post"
                            class="mb-4 ml-auto grid w-full gap-2 group-data-[loading]/cart-form:pointer-events-none {%- if cart.item_count < 1 %} pointer-events-none opacity-50 {%- endif -%}"
                        >
                            {%- liquid
                                assign checkout_button_label = 'cart.main-cart.checkout' | t
                            -%}
                            {%- render 'component.button',
                                type: 'submit',
                                name: 'checkout',
                                label: checkout_button_label,
                                style: 'primary',
                                size: 'medium',
                                class: 'w-full justify-center'
                            -%}
                        </form>
                        {%- render 'component.payment-methods',
                            container_classes: 'mt-2 flex flex-wrap justify-center gap-x-3 gap-y-3'
                        -%}
                        {%- if section.settings.after_pay_text != blank -%}
                            <p class="mt-4 text-center text-xs text-brand-50">
                                {{ section.settings.after_pay_text }}
                            </p>
                        {%- endif -%}
                    </div>
                {%- endif -%}
            </footer>
        </div>
    </div>
</cart-form>

{% schema %}
{
    "name": "Main Cart",
    "settings": [
        {
            "type": "textarea",
            "id": "shipping_message",
            "label": "Shipping message",
            "default": "Order now and your order will be shipped today"
        },
        {
            "type": "text",
            "id": "after_pay_text",
            "label": "After pay text",
            "default": "or choice for after pay"
        }
    ],
    "blocks": []
}
{% endschema %}
