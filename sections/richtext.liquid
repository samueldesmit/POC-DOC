{%- liquid
    assign s = section.settings
    assign section_id = 'section-' | append: section.id

    assign show_section = true

    if s.visibility_audience == 'premium_only'
        assign show_section = false
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = true
            endif
        endif
    elsif s.visibility_audience == 'non_premium_only'
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = false
            endif
        endif
    endif
-%}

{% if show_section %}
<div
    id="{{ section_id }}"
    class="{{ s.mobile_margin }} {{ s.desktop_margin }} bg-background"
>
    {% render 'section-colors', current_section: section %}
    {% if s.animation_style != blank and s.animation_style != 'none' -%}
        <gsap-section data-animation="{{ s.animation_style }}">
    {%- endif %}
    <div
        class="{{ s.mobile_padding }} {{ s.desktop_padding }} {% if s.container %}container{% else %}container-small{% endif %} [&_a]:underline {{ s.content_alignment }}"
    >
        {%- for block in section.blocks -%}
            {% assign b = block.settings %}
            {%- case block.type -%}
                {%- when 'heading' -%}
                    {% if b.heading != blank %}
                        {% style %}
                            #heading-{{ block.id }} {
                                font-size: {{ b.mobile_font_size }};
                                font-weight: {{ b.font_weight }};
                                margin-bottom: {{ b.margin_bottom }};
                            }
                            @media (min-width: 1024px) {
                                #heading-{{ block.id }} {
                                    font-size: {{ b.desktop_font_size }};
                                }
                            }
                        {% endstyle %}
                        <h2
                            id="heading-{{ block.id }}"
                            {{ block.shopify_attributes }}
                            class="{{ b.font_family }} text-primary tracking-[-0.88px]"
                        >
                            {{ b.heading }}
                        </h2>
                    {% endif %}
                {%- when 'text' -%}
                    {% if b.text != blank %}
                        {% style %}
                            #text-{{ block.id }} {
                                font-size: {{ b.mobile_font_size }};
                                font-weight: {{ b.font_weight }};
                                margin-bottom: {{ b.margin_bottom }};
                            }
                            #text-{{ block.id }}:last-child {
                                margin-bottom: 0;
                            }
                            @media (min-width: 1024px) {
                                #text-{{ block.id }} {
                                    font-size: {{ b.desktop_font_size }};
                                }
                            }
                        {% endstyle %}
                        <div
                            id="text-{{ block.id }}"
                            {{ block.shopify_attributes }}
                            class="{{ b.font_family }} space-y-5 [&_ol]:list-decimal [&_ol]:pl-5 [&_ul]:list-disc [&_ul]:pl-5 [&_h1]:headline-lg [&_h2]:headline-md [&_h3]:headline-md [&_h4]:headline-sm [&_h5]:headline-sm [&_h6]:headline-sm text-secondary"
                        >
                            {{ b.text }}
                        </div>
                    {% endif %}
            {%- endcase -%}
        {%- endfor -%}
    </div>
    {% if s.animation_style != blank and s.animation_style != 'none' -%}
        </gsap-section>
    {%- endif %}
</div>
{% if template == 'article' %}
    {% render 'schema.article' %}
{% endif %}
{% endif %}

