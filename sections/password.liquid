{%- liquid
    assign s = section.settings
    assign has_mobile_image = false
    if s.mobile_image != blank
        assign has_mobile_image = true
    endif
-%}

{% render 'section-colors', current_section: section %}

<div
    id="section-{{ section.id }}"
    class="relative min-h-screen flex flex-col"
>
    <responsive-media
        class="absolute inset-0 h-full w-full"
        data-visible
    >
        {% if has_mobile_image %}
            <div class="hidden lg:block h-full w-full">
        {% endif %}

        {% if s.image != blank %}
            {{
                s.image
                | image_url: width: 1920
                | image_tag:
                    class: 'object-cover w-full h-full',
                    loading: 'eager',
                    fetchpriority: 'high',
                    widths: '375,750,1100,1440,1920',
                    sizes: '100vw'
            -}}
        {% else %}
            <div class="h-full w-full flex items-center justify-center bg-surface-100">
                {{
                    'image'
                    | placeholder_svg_tag: 'placeholder-svg w-full h-full bg-gray-100 text-white'
                }}
            </div>
        {% endif %}

        {% if has_mobile_image %}
            </div>
            <div class="lg:hidden h-full w-full">
                {{
                    s.mobile_image
                    | image_url: width: 750
                    | image_tag:
                        class: 'object-cover w-full h-full',
                        loading: 'eager',
                        fetchpriority: 'high',
                        widths: '375,750',
                        sizes: '100vw'
                -}}
            </div>
        {% endif %}

        {% if s.enable_overlay %}
            {% if s.overlay_type == 'color' %}
                <div class="absolute inset-0 bg-black" style="opacity: {{ s.overlay_opacity | divided_by: 100.0 }};"></div>
            {% elsif s.mobile_gradient != blank
                and s.desktop_gradient != blank
            %}
                {% render 'component.gradient',
                    mobile_bg: s.mobile_gradient,
                    desktop_bg: s.desktop_gradient,
                    mobile_visible: true,
                    desktop_visible: true
                %}
            {% endif %}
        {% endif %}
    </responsive-media>

    <div class="relative z-10 flex flex-col min-h-screen">
        {%- comment -%} Header with shop name {%- endcomment -%}
        <header class="container pt-6 lg:pt-8">
            {% if s.logo != blank %}
                <span class="inline-block">
                    {{
                        s.logo
                        | image_url: width: 200
                        | image_tag:
                            class: 'h-8 lg:h-10 w-auto',
                            loading: 'eager'
                    }}
                </span>
            {% else %}
                <span class="text-primary text-xl font-cormorant-garamond font-bold">
                    {{ shop.name }}
                </span>
            {% endif %}
        </header>

        {%- comment -%} Main content {%- endcomment -%}
        <div class="flex-1 flex items-center justify-center">
            <div class="container">
                <div class="flex flex-col items-center text-center w-full max-w-[500px] lg:max-w-[600px] mx-auto space-y-6 font-light">
                    {% if s.title != blank %}
                        <div class="text-primary text-[30px] lg:text-[55px] leading-[120%] font-cormorant-garamond font-bold lg:font-semibold">
                            {{ s.title }}
                        </div>
                    {% endif %}

                    {% if s.text != blank %}
                        <p class="font-normal text-secondary text-[16px] lg:text-[18px] tracking-[-0.022em] lg:tracking-normal leading-[150%]">
                            {{ s.text }}
                        </p>
                    {% endif %}

                    {%- if s.show_password_form -%}
                        <div class="w-full max-w-[400px]">
                            {%- form 'storefront_password' -%}
                                {{ form.errors | default_errors }}
                                <fieldset class="flex flex-col lg:flex-row gap-2">
                                    <input
                                        id="password"
                                        class="w-full appearance-none border border-solid border-white/30 bg-white/10 backdrop-blur-sm px-4 py-3 text-primary placeholder:text-primary/50 focus:outline-none focus:border-white/60 text-[14px]"
                                        name="password"
                                        type="password"
                                        placeholder="{{ 'general.password.placeholder' | t | default: 'Wachtwoord' }}"
                                        required
                                    >
                                    {% render 'component.button',
                                        label: s.submit_text,
                                        title: s.submit_text,
                                        type: 'submit',
                                        class: 'items-center justify-center',
                                        aria_label: s.submit_text,
                                        style: s.button_style,
                                        size: 'medium',
                                        disabled: false,
                                        loading: false,
                                        translate: false
                                    %}
                                </fieldset>
                            {%- endform -%}
                        </div>
                    {%- endif -%}
                </div>
            </div>
        </div>

        {%- comment -%} Footer {%- endcomment -%}
        <footer class="container pb-6 lg:pb-8 text-center">
            <p class="text-secondary text-[12px] lg:text-[14px] opacity-60">
                &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
            </p>
        </footer>
    </div>
</div>

{% schema %}
{
    "name": "Password",
    "tag": "section",
    "class": "section_password",
    "settings": [
        {
            "type": "header",
            "content": "Background Image"
        },
        {
            "id": "image",
            "type": "image_picker",
            "label": "Background image (desktop)"
        },
        {
            "id": "mobile_image",
            "type": "image_picker",
            "label": "Background image (mobile)",
            "info": "Optional: upload a different image for mobile. Falls back to desktop image if empty."
        },
        {
            "type": "header",
            "content": "Overlay"
        },
        {
            "type": "checkbox",
            "id": "enable_overlay",
            "default": true,
            "label": "Enable overlay"
        },
        {
            "type": "select",
            "id": "overlay_type",
            "label": "Overlay type",
            "options": [
                {
                    "value": "gradient",
                    "label": "Gradient"
                },
                {
                    "value": "color",
                    "label": "Color overlay"
                }
            ],
            "default": "gradient",
            "visible_if": "{{ section.settings.enable_overlay == true }}"
        },
        {
            "type": "color_background",
            "id": "mobile_gradient",
            "label": "Gradient [Mobile]",
            "info": "Click on color-picker to adjust gradient colors, direction and opacity",
            "default": "linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.4) 100%)",
            "visible_if": "{{ section.settings.enable_overlay == true and section.settings.overlay_type == 'gradient' }}"
        },
        {
            "type": "color_background",
            "id": "desktop_gradient",
            "label": "Gradient [Desktop]",
            "info": "Click on color-picker to adjust gradient colors, direction and opacity",
            "default": "linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.4) 100%)",
            "visible_if": "{{ section.settings.enable_overlay == true and section.settings.overlay_type == 'gradient' }}"
        },
        {
            "type": "range",
            "id": "overlay_opacity",
            "label": "Overlay opacity",
            "min": 0,
            "max": 100,
            "step": 5,
            "unit": "%",
            "default": 30,
            "visible_if": "{{ section.settings.enable_overlay == true and section.settings.overlay_type == 'color' }}"
        },
        {
            "type": "header",
            "content": "Colors"
        },
        {
            "type": "color",
            "id": "primary_text_color",
            "label": "Title color",
            "default": "#FFFFFF"
        },
        {
            "type": "color",
            "id": "secondary_text_color",
            "label": "Text color",
            "default": "#FFFFFF"
        },
        {
            "type": "color",
            "id": "secondary_button_color",
            "label": "Button background color",
            "default": "rgba(0,0,0,0)"
        },
        {
            "type": "color",
            "id": "secondary_button_text_color",
            "label": "Button text color",
            "default": "#FFFFFF"
        },
        {
            "type": "header",
            "content": "Logo"
        },
        {
            "id": "logo",
            "type": "image_picker",
            "label": "Logo",
            "info": "Optional: upload a logo. Falls back to shop name if empty."
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Binnenkort beschikbaar"
        },
        {
            "type": "textarea",
            "id": "text",
            "label": "Text",
            "default": "We werken hard aan onze nieuwe webshop. Kom snel terug!"
        },
        {
            "type": "header",
            "content": "Password Form"
        },
        {
            "type": "checkbox",
            "id": "show_password_form",
            "label": "Show password form",
            "default": true
        },
        {
            "type": "text",
            "id": "submit_text",
            "label": "Submit button text",
            "default": "Toegang"
        },
        {
            "type": "select",
            "id": "button_style",
            "label": "Button style",
            "options": [
                {
                    "value": "primary",
                    "label": "Primary"
                },
                {
                    "value": "secondary",
                    "label": "Secondary"
                }
            ],
            "default": "secondary"
        }
    ]
}
{% endschema %}
