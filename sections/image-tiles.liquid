{% liquid
    assign s = section.settings
    assign section_id = 'section-' | append: section.id

    assign show_section = true

    if s.visibility_audience == 'premium_only'
        assign show_section = false
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = true
            endif
        endif
    elsif s.visibility_audience == 'non_premium_only'
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = false
            endif
        endif
    endif
%}

{% if show_section %}
<div
    id="{{ section_id }}"
    class="{{ s.mobile_margin }} {{ s.desktop_margin }} bg-background"
>
    {% render 'section-colors', current_section: section %}
    {% if s.animation_style != blank and s.animation_style != 'none' -%}
        <gsap-section data-animation="{{ s.animation_style }}">
    {%- endif %}
    <div class="container {{ s.mobile_padding }} {{ s.desktop_padding }}">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-9">
            {%- for block in section.blocks -%}
                {% assign b = block.settings %}
                <div
                    {{ block.shopify_attributes }}
                    class="flex flex-col"
                >
                    <div class="aspect-[424/499] mb-3 overflow-hidden">
                        {%- if b.image != blank -%}
                            {{
                                b.image
                                | image_url: width: 848
                                | image_tag:
                                    class: 'w-full h-full object-cover',
                                    loading: 'lazy',
                                    widths: '424, 636, 848',
                                    sizes: '(min-width: 1024px) 33vw, 100vw'
                            }}
                        {%- else -%}
                            {{
                                'image'
                                | placeholder_svg_tag: 'w-full h-full bg-surface-100'
                            }}
                        {%- endif -%}
                    </div>
                    {%- if b.title != blank -%}
                        <h3 class="font-cormorant-garamond text-[1.875rem] leading-tight text-primary mb-4">
                            {{ b.title }}
                        </h3>
                    {%- endif -%}
                    {%- if b.description != blank -%}
                        <p class="text-[0.9375rem] leading-tight text-secondary">
                            {{ b.description }}
                        </p>
                    {%- endif -%}
                </div>
            {%- endfor -%}
        </div>
    </div>
    {% if s.animation_style != blank and s.animation_style != 'none' -%}
        </gsap-section>
    {%- endif %}
</div>
{% endif %}

{% schema %}
{
    "name": "Image Tiles",
    "tag": "section",
    "class": "section-image-tiles",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
        {
            "type": "header",
            "content": "Visibility"
        },
        {
            "type": "select",
            "id": "visibility_audience",
            "label": "Visibility (audience)",
            "options": [
                {
                    "value": "everyone",
                    "label": "Everyone"
                },
                {
                    "value": "premium_only",
                    "label": "Only premium-club customers"
                },
                {
                    "value": "non_premium_only",
                    "label": "Only non premium-club customers"
                }
            ],
            "default": "everyone"
        },
        {
            "type": "header",
            "content": "Documentation for this section",
            "info": "Click [here](https://strix-net.atlassian.net/wiki/x/GoBa3w) for more information."
        },
        {
            "type": "header",
            "content": "Section Styling"
        },
        {
            "type": "checkbox",
            "id": "section_styling",
            "label": "Add styling to section",
            "info": "If enabled this shows the settings to set the color scheme, spacing, and margin for the section.",
            "default": false
        },
        {
            "type": "header",
            "content": "Section Spacing",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_padding",
            "label": "Mobile padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "py-0",
                    "label": "None"
                },
                {
                    "value": "py-2",
                    "label": "S - 8px"
                },
                {
                    "value": "py-4",
                    "label": "M - 16px"
                },
                {
                    "value": "py-6",
                    "label": "L - 24px"
                },
                {
                    "value": "py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "py-10",
                    "label": "2XL - 40px"
                },
                {
                    "value": "py-12",
                    "label": "3XL - 48px"
                },
                {
                    "value": "py-16",
                    "label": "4XL - 64px"
                }
            ],
            "default": "py-0"
        },
        {
            "type": "select",
            "id": "desktop_padding",
            "label": "Desktop padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "lg:py-0",
                    "label": "None"
                },
                {
                    "value": "lg:py-2",
                    "label": "S - 8px"
                },
                {
                    "value": "lg:py-4",
                    "label": "M - 16px"
                },
                {
                    "value": "lg:py-6",
                    "label": "L - 24px"
                },
                {
                    "value": "lg:py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "lg:py-10",
                    "label": "2XL - 40px"
                },
                {
                    "value": "lg:py-12",
                    "label": "3XL - 48px"
                },
                {
                    "value": "lg:py-16",
                    "label": "4XL - 64px"
                }
            ],
            "default": "lg:py-0"
        },
        {
            "type": "header",
            "content": "Section Margin",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_margin",
            "label": "Mobile Section margin",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "mb-0",
                    "label": "None"
                },
                {
                    "value": "mb-4",
                    "label": "Small - 16px"
                },
                {
                    "value": "mb-8",
                    "label": "Medium - 32px"
                },
                {
                    "value": "mb-12",
                    "label": "Large - 48px"
                }
            ],
            "default": "mb-0"
        },
        {
            "type": "select",
            "id": "desktop_margin",
            "label": "Desktop Section margin",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "lg:mb-0",
                    "label": "None"
                },
                {
                    "value": "lg:mb-8",
                    "label": "Small - 32px"
                },
                {
                    "value": "lg:mb-12",
                    "label": "Medium - 48px"
                },
                {
                    "value": "lg:mb-16",
                    "label": "Large - 64px"
                }
            ],
            "default": "lg:mb-0"
        },
        {
            "type": "header",
            "content": "Colors",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "background",
            "label": "Section background color",
            "default": "#FFFFFF",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "primary_text_color",
            "label": "Primary text color",
            "default": "#525252",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "secondary_text_color",
            "label": "Secondary text color",
            "default": "#525252",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "header",
            "content": "Animation"
        },
        {
            "type": "select",
            "id": "animation_style",
            "label": "Scroll animation",
            "info": "Adds a subtle entrance animation when the section scrolls into view.",
            "options": [
                { "value": "none", "label": "None" },
                { "value": "fade-up", "label": "Fade up" },
                { "value": "fade-in", "label": "Fade in" },
                { "value": "stagger-up", "label": "Stagger up" },
                { "value": "slide-in-left", "label": "Slide in from left" },
                { "value": "slide-in-right", "label": "Slide in from right" }
            ],
            "default": "none"
        }
    ],
    "blocks": [
        {
            "type": "tile",
            "name": "Tile",
            "limit": 3,
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Title",
                    "default": "Our range"
                },
                {
                    "type": "textarea",
                    "id": "description",
                    "label": "Description",
                    "default": "With personalized advice and the service of our wine experts, we help you enjoy the world's finest wines even more."
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Image Tiles",
            "blocks": [
                {
                    "type": "tile",
                    "settings": {
                        "title": "Our range",
                        "description": "With personalized advice and the service of our wine experts, we help you enjoy the world's finest wines even more."
                    }
                },
                {
                    "type": "tile",
                    "settings": {
                        "title": "Our taste guarantee",
                        "description": "The range includes all the leading wine regions and wine styles, crafted by the region's best winemakers."
                    }
                },
                {
                    "type": "tile",
                    "settings": {
                        "title": "Personal advice",
                        "description": "Would you like personalized advice on wine and food pairings, building your wine collection, or simply finding the perfect wine for you?"
                    }
                }
            ]
        }
    ]
}
{% endschema %}
