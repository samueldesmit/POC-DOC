{% liquid
    assign s = section.settings
    assign section_id = 'section-' | append: section.id
    assign show_section = true

    if s.visibility_audience == 'premium_only'
        assign show_section = false
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = true
            endif
        endif
    elsif s.visibility_audience == 'non_premium_only'
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = false
            endif
        endif
    endif

    comment
        Determine article source: blocks override the blog setting
    endcomment
    assign has_block_articles = false
    for block in section.blocks
        if block.settings.article != blank
            assign has_block_articles = true
            break
        endif
    endfor

    assign use_blog = false
    if has_block_articles == false and s.blog != blank
        assign use_blog = true
        assign blog_articles = s.blog.articles
    endif
%}

{% if show_section %}
    <div
        id="{{ section_id }}"
        class="{{ s.mobile_margin }} {{ s.desktop_margin }} bg-background overflow-hidden"
    >
        {% render 'section-colors', current_section: section %}
        <div class="container {{ s.mobile_padding }} {{ s.desktop_padding }}">
            {% if s.animation_style != blank and s.animation_style != 'none' -%}
                <gsap-section data-animation="{{ s.animation_style }}">
            {%- endif %}
            <splide-section
                data-splide-type="slide"
                data-splide-per-page-mobile="1.2"
                data-splide-per-page-desktop="4.1"
                data-splide-gap-mobile="2rem"
                data-splide-gap-desktop="2rem"
                data-splide-autoplay="false"
                data-splide-pagination="false"
                data-splide-omit-end="true"
                data-splide-drag="true"
                data-splide-arrows="true"
                class="flex justify-between items-center"
            >
                <div class="splide w-full">
                    <div
                        class="
                            flex items-end justify-between mb-6 font-cormorant-garamond font-normal lg:mb-13 text-[30px]
                            lg:text-[40px]
                        "
                    >
                        {%- if s.title != blank -%}
                            {%- render 'component.heading',
                                variant: 'lg',
                                tag: 'h2',
                                content: s.title,
                                class: 'text-primary text-[30px] lg:text-[40px] leading-[120%] font-semibold'
                            -%}
                        {%- endif -%}

                        {% render 'component.splide-arrows',
                            style: 'primary',
                            icon_class: 'size-5',
                            container_class: 'splide__arrows splide__arrows--ltr items-end pointer-events-none z-10 flex'
                        %}
                    </div>

                    <div class="h-full !overflow-visible splide__track w-full">
                        <ul class="splide__list flex">
                            {% if use_blog %}
                                {% for article in blog_articles %}
                                    {%- liquid
                                        assign article_is_restricted = false
                                        if article.metafields.custom.premium_club_exclusive.value == true
                                            assign article_is_restricted = true
                                            if customer and customer.tags contains 'premium-club'
                                                assign article_is_restricted = false
                                            endif
                                        endif
                                    -%}
                                    {%- unless article_is_restricted -%}
                                        <li class="splide__slide md:col-span-1">
                                            <div
                                                role="tabpanel"
                                                aria-roledescription="slide"
                                            >
                                                {% render 'component.article-card',
                                                    article: article,
                                                    class: 'col-span-1'
                                                %}
                                            </div>
                                        </li>
                                    {%- endunless -%}
                                {% endfor %}
                            {% else %}
                                {% for block in section.blocks %}
                                    {%- liquid
                                        assign b = block.settings
                                    -%}
                                    {%- if b.article != blank -%}
                                        {%- liquid
                                            assign article_is_restricted = false
                                            if b.article.metafields.custom.premium_club_exclusive.value == true
                                                assign article_is_restricted = true
                                                if customer and customer.tags contains 'premium-club'
                                                    assign article_is_restricted = false
                                                endif
                                            endif
                                        -%}
                                        {%- unless article_is_restricted -%}
                                            <li class="splide__slide md:col-span-1">
                                                <div
                                                    role="tabpanel"
                                                    aria-roledescription="slide"
                                                >
                                                    {% render 'component.article-card',
                                                        article: b.article,
                                                        class: 'col-span-1'
                                                    %}
                                                </div>
                                            </li>
                                        {%- endunless -%}
                                    {%- endif -%}
                                {% endfor %}
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </splide-section>
            {% if s.animation_style != blank and s.animation_style != 'none' -%}
                </gsap-section>
            {%- endif %}
            {% if s.button_text != blank and s.button_url != blank %}
                {% render 'component.button',
                    label: s.button_text,
                    title: s.button_text,
                    href: s.button_url,
                    class: 'w-fit md:w-max justify-center text-center !font-normal m-auto mt-8 lg:mt-13 text-[0.875rem]',
                    id: s.button_text,
                    attributes: '',
                    type: 'button',
                    name: s.button_text,
                    aria_label: s.button_text,
                    aria_describedby: s.button_text,
                    style: s.button_style,
                    size: '',
                    icon: '',
                    icon_position: '',
                    icon_class: '',
                    css_variables: '',
                    disabled: false,
                    loading: false,
                    translate: false
                %}
            {% endif %}
        </div>
    </div>
{% endif %}

{% schema %}
{
    "name": "Blog Slider",
    "tag": "section",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
        {
            "type": "header",
            "content": "Documentation for this section",
            "info": "Click [here](https://strix-net.atlassian.net/wiki/x/KoCe3) for more information."
        },
        {
            "type": "select",
            "id": "visibility_audience",
            "label": "Visibility (audience)",
            "options": [
                {
                    "value": "everyone",
                    "label": "Everyone"
                },
                {
                    "value": "premium_only",
                    "label": "Only premium-club customers"
                },
                {
                    "value": "non_premium_only",
                    "label": "Only non premium-club customers"
                }
            ],
            "default": "everyone"
        },
        {
            "type": "header",
            "content": "Section Styling"
        },
        {
            "type": "checkbox",
            "id": "section_styling",
            "label": "Add styling to section",
            "info": "If enabled this shows the settings to set the color scheme, spacing, and margin for the section.",
            "default": false
        },
        {
            "type": "header",
            "content": "Section Spacing",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_padding",
            "label": "Mobile padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "py-0",
                    "label": "None"
                },
                {
                    "value": "py-2",
                    "label": "S - 8px"
                },
                {
                    "value": "py-4",
                    "label": "M - 16px"
                },
                {
                    "value": "py-6",
                    "label": "L - 24px"
                },
                {
                    "value": "py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "py-10",
                    "label": "2XL - 40px"
                },
                {
                    "value": "py-12",
                    "label": "3XL - 48px"
                },
                {
                    "value": "py-16",
                    "label": "4XL - 64px"
                }
            ],
            "default": "py-0"
        },
        {
            "type": "select",
            "id": "desktop_padding",
            "label": "Desktop padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "lg:py-0",
                    "label": "None"
                },
                {
                    "value": "lg:py-2",
                    "label": "S - 8px"
                },
                {
                    "value": "lg:py-4",
                    "label": "M - 16px"
                },
                {
                    "value": "lg:py-6",
                    "label": "L - 24px"
                },
                {
                    "value": "lg:py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "lg:py-10",
                    "label": "2XL - 40px"
                },
                {
                    "value": "lg:py-12",
                    "label": "3XL - 48px"
                },
                {
                    "value": "lg:py-16",
                    "label": "4XL - 64px"
                }
            ],
            "default": "lg:py-0"
        },
        {
            "type": "header",
            "content": "Section Margin",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_margin",
            "label": "Mobile section margin",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "mb-0",
                    "label": "None"
                },
                {
                    "value": "mb-4",
                    "label": "Small - 16px"
                },
                {
                    "value": "mb-8",
                    "label": "Medium - 32px"
                },
                {
                    "value": "mb-12",
                    "label": "Large - 48px"
                }
            ],
            "default": "mb-0"
        },
        {
            "type": "select",
            "id": "desktop_margin",
            "label": "Desktop section margin",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "lg:mb-0",
                    "label": "None"
                },
                {
                    "value": "lg:mb-8",
                    "label": "Small - 32px"
                },
                {
                    "value": "lg:mb-12",
                    "label": "Medium - 48px"
                },
                {
                    "value": "lg:mb-16",
                    "label": "Large - 64px"
                }
            ],
            "default": "lg:mb-0"
        },
        {
            "type": "header",
            "content": "Colors",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "background",
            "label": "Section background color",
            "default": "#FFFFFF",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "primary_button_color",
            "label": "Primary button background color",
            "default": "#CFDADD",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "primary_button_text_color",
            "label": "Primary button text color",
            "default": "#282828",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "secondary_button_color",
            "label": "Secondary button background color",
            "default": "#000000",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "color",
            "id": "secondary_button_text_color",
            "label": "Secondary button text color",
            "default": "#FFFFFF",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "header",
            "content": "Content"
        },
        {
            "type": "blog",
            "id": "blog",
            "label": "Blog",
            "info": "Select a blog to automatically show the latest articles. Adding individual blog post blocks below will override this setting."
        },
        {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Exclusive access for true wine lovers"
        },
        {
            "type": "header",
            "content": "Button"
        },
        {
            "type": "text",
            "id": "button_text",
            "label": "Button text",
            "default": "Read all articles"
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "Button url"
        },
        {
            "type": "select",
            "id": "button_style",
            "label": "Button style",
            "options": [
                {
                    "value": "primary",
                    "label": "Primary"
                },
                {
                    "value": "secondary",
                    "label": "Secondary"
                }
            ],
            "default": "primary"
        },
        {
            "type": "header",
            "content": "Animation"
        },
        {
            "type": "select",
            "id": "animation_style",
            "label": "Scroll animation",
            "info": "Adds a subtle entrance animation when the section scrolls into view.",
            "options": [
                { "value": "none", "label": "None" },
                { "value": "fade-up", "label": "Fade up" },
                { "value": "fade-in", "label": "Fade in" },
                { "value": "stagger-up", "label": "Stagger up" },
                { "value": "slide-in-left", "label": "Slide in from left" },
                { "value": "slide-in-right", "label": "Slide in from right" }
            ],
            "default": "none"
        }
    ],
    "blocks": [
        {
            "type": "blog_post",
            "name": "Blog Post",
            "settings": [
                {
                    "type": "article",
                    "id": "article",
                    "label": "Article"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Blog Slider",
            "settings": {}
        }
    ]
}
{% endschema %}
