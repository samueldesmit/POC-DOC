{%- liquid
    assign s = section.settings
    assign section_id = 'section-' | append: section.id

    assign show_section = true

    if s.visibility_audience == 'premium_only'
        assign show_section = false
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = true
            endif
        endif
    elsif s.visibility_audience == 'non_premium_only'
        if customer
            if customer.tags contains 'premium-club'
                assign show_section = false
            endif
        endif
    endif
-%}

{% if show_section %}
<div
    class="{{ s.mobile_margin }} {{ s.desktop_margin }}"
    id="{{ section_id }}"
>
    {% render 'section-colors', current_section: section %}
    <div
        class="{{ s.mobile_padding }} {{ s.desktop_padding }}"
    >
        <h1>Section Here</h1>
    </div>
</div>
{% endif %}

{% schema %}
{
    "name": "Section Name",
    "tag": "section",
    "class": "section-name",
    "settings": [
        {
            "type": "header",
            "content": "Visibility"
        },
        {
            "type": "select",
            "id": "visibility_audience",
            "label": "Visibility (audience)",
            "options": [
                {
                    "value": "everyone",
                    "label": "Everyone"
                },
                {
                    "value": "premium_only",
                    "label": "Only premium-club customers"
                },
                {
                    "value": "non_premium_only",
                    "label": "Only non premium-club customers"
                }
            ],
            "default": "everyone"
        },
        {
            "type": "header",
            "content": "Documentation for this section",
            "info": "Click [here](https://strix-net.atlassian.net/wiki/spaces/TWL/pages/3720183810/Section+Winery+Selection) for more information."
        },
        {
            "type": "header",
            "content": "Section Styling"
        },
        {
            "type": "checkbox",
            "id": "section_styling",
            "label": "Add styling to section",
            "info": "If enabled this shows the settings to set the color scheme, spacing, and margin for the section.",
            "default": false
        },
        {
            "type": "header",
            "content": "Section Spacing",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_padding",
            "label": "Mobile padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "py-0",
                    "label": "None"
                },
                {
                    "value": "py-2",
                    "label": "S - 8px"
                },
                {
                    "value": "py-4",
                    "label": "M - 16px"
                },
                {
                    "value": "py-6",
                    "label": "L - 24px"
                },
                {
                    "value": "py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "py-10",
                    "label": "2XL - 40px"
                },
                {
                    "value": "py-12",
                    "label": "3XL - 48px"
                },
                {
                    "value": "py-16",
                    "label": "4XL - 64px"
                }
            ],
            "default": "py-0"
        },
        {
            "type": "select",
            "id": "desktop_padding",
            "label": "Desktop padding",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "lg:py-0",
                    "label": "None"
                },
                {
                    "value": "lg:py-2",
                    "label": "S - 8px"
                },
                {
                    "value": "lg:py-4",
                    "label": "M - 16px"
                },
                {
                    "value": "lg:py-6",
                    "label": "L - 24px"
                },
                {
                    "value": "lg:py-8",
                    "label": "XL - 32px"
                },
                {
                    "value": "lg:py-10",
                    "label": "2XL - 40px"
                },
                {
                    "value": "lg:py-12",
                    "label": "3XL - 48px"
                },
                {
                    "value": "lg:py-16",
                    "label": "4XL - 64px"
                }
            ],
            "default": "lg:py-0"
        },
        {
            "type": "header",
            "content": "Section Margin",
            "visible_if": "{{ section.settings.section_styling == true }}"
        },
        {
            "type": "select",
            "id": "mobile_margin",
            "label": "Mobile Section margin",
            "visible_if": "{{ section.settings.section_styling == true }}",
            "options": [
                {
                    "value": "mb-0",
                    "label": "None"
                },
                {
                    "value": "mb-4",
                    "label": "Small - 16px"
                },
                {
                    "value": "mb-8",
