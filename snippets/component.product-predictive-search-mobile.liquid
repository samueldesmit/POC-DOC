{% doc %}
    Renders the product item with image, title, price, and optional add to cart functionality.

    @param {object} product - The product object (required)
    @param {boolean} eager - Eager load first product image (default: false)
    @param {object} current_variant - The current variant object (default: product.selected_or_first_available_variant)
    @param {boolean} add_to_cart - Show add to cart button (default: false)
    @param {boolean} product_link - Changes article image and description wrappers into links (default: false)
    @param {string} class - CSS classes for the product card (default: '')

    @example
    {%- render 'component.product',
        product: product,
        eager: true,
        add_to_cart: true
    -%}
{% enddoc %}

{%- liquid
    if eager
        assign loading = 'eager'
    else
        assign loading = 'lazy'
    endif

    assign current_variant = current_variant | default: product.selected_or_first_available_variant
    assign add_to_cart = add_to_cart | default: false

    assign current_variant = product.selected_or_first_available_variant
    assign add_to_cart = add_to_cart | default: false
    assign product_tag_link = 'div'

    if product_link
        assign product_tag_link = 'a'
    endif

-%}

<plp-product-card
    id="current-variant-{{ current_variant.id }}"
    class="relative group/plp h-full"
    data-product-handle="{{ product.handle }}"
    data-variant-id="{{ current_variant.id }}"
    data-variants="
        [
          {%- for variant in product.variants -%}
            {
              'variantId': {{ variant.id }},
              {%- for option in variant.options -%}
                '{{ product.options[forloop.index0] | downcase }}': '{{ option | escape }}'{% unless forloop.last %},{% endunless %}
              {%- endfor -%}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
    "
>
    <div class="grid grid-cols-[110px_1fr] gap-3">
        <div class="relative bg-white w-full mr-5">
            <a
                class="absolute inset-0 z-10"
                href="{{- product.url -}}"
            ></a>
            {% if product.featured_image != blank %}
                <responsive-media class="{{ class }} aspect-square w-full {% if product.images[1] %} lg:group-hover:opacity-0 transition-opacity duration-300 {% endif %}">
                    {{-
                        current_variant.featured_image
                        | default: product.featured_image
                        | image_url: width: 1024
                        | image_tag:
                            sizes: '(max-width: 1024px) 100vw, 50vw',
                            class: 'w-full object-contain',
                            loading: loading
                    -}}
                </responsive-media>

            {% else %}
                <div class="w-full flex items-center justify-center text-white aspect-square">
                    {{
                        'image'
                        | placeholder_svg_tag: 'placeholder-svg w-full h-full bg-gray-100 text-white aspect-square'
                    }}
                </div>
            {% endif %}
        </div>

        <div class="flex flex-col justify-start items-start w-full">
            {% if product.metafields.custom.winery != blank %}
                <a
                    href="{{ product.metafields.custom.winery.value.url }}"
                    class="text-secondary text-[0.6875rem] md:heading-2xs uppercase tracking-[0.08em] mb-1 hover:underline"
                >
                    {{- product.metafields.custom.winery.value.title -}}
                </a>
            {% endif %}
            <{{ product_tag_link }}
                class="product-card__content"
                href="{{- product.url -}}"
            >
                <p class="font-cormorant-garamond text-base md:text-[1.25rem] text-primary font-normal mb-3 md:mb-4">
                    {{- product.title -}}
                </p>
            </{{ product_tag_link }}>
            <div class="flex flex-col items-center gap-1">
                {%- render 'component.price',
                    current_variant: current_variant,
                    class: 'font-semibold text-primary text-xs',
                    price_class: 'font-inter font-bold'
                -%}
            </div>
        </div>
    </div>
</plp-product-card>
