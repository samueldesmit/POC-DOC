{%- assign days_product_price_valid_until = 10 | times: 86400 -%}

<script type="application/ld+json">
  {
      "@context": "https://schema.org",
      "@type": "Product",
      "productID": {{ product.id | json }},
      {%- comment -%}
          In case the color and colorSwatch are available on varait level, please add them here. Else remove the properties.
          {% if some_color_metafield %}
              "color": "{{ some_color_metafield }}",
          {% endif %}
          {% if some_color_swatch_metafield %}
              "colorSwatch": "",
          {% endif %}
      {%- endcomment -%}
      "offers": [
      {%- comment -%}
          In case your product variants have the same price and are only different by size (so not color or material i.e.), then you could consider simplifying the JSON-LD by only using the default variant.
          More about that here: https://www.schemaapp.com/schema-markup/schema-org-variable-products-productmodels-offers/
      {%- endcomment -%}
      {%- for variant in product.variants -%}
        {
          "@type": "Offer",
          "name": {% if product.has_only_default_variant %}{{ product.title | json }}{% else %}{{ variant.title | json }}{% endif %},
          {%- # Check the different properties here: https://schema.org/ItemAvailability. I.e. PreOrder -%}
          "availability": {%- if variant.available -%}"https://schema.org/InStock"{%- elsif variant.incoming -%}"https://schema.org/BackOrder"{% else %}"https://schema.org/OutOfStock"{%- endif -%},
          "price": {{ variant.price | divided_by: 100.0 | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "priceValidUntil": "{{ 'now' | date: '%s' | plus: days_product_price_valid_until | date: '%Y-%m-%d' }}",
          {%- comment -%}
              In case the color and colorSwatch are available on varait level, please add them here. Else remove the properties.
              {% if some_color_metafield %}
                  "color": "{{ some_color_metafield }}",
              {% endif %}
              {% if some_color_swatch_metafield %}
                  "colorSwatch": "",
              {% endif %}
          {%- endcomment -%}
          {%- if variant.sku != blank -%}
            "sku": {{ variant.sku | json }},
          {%- endif -%}
          {%- if shop.refund_policy.body != blank -%}
            "hasMerchantReturnPolicy": {
              "merchantReturnLink": {{ shop.refund_policy.url | prepend: request.origin | json }}
            },
          {%- endif -%}
          {%- if shop.shipping_policy.body != blank -%}
            "shippingDetails": {
              "shippingSettingsLink": {{ shop.shipping_policy.url | prepend: request.origin | json }}
            },
          {%- endif -%}
          "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}"
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    {%- # Are there reviews available and if so, are they stored on the product.metafields.reviews? -%}
    {%- if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count.value > 0 -%}
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "{{ product.metafields.reviews.rating.value }}",
        "reviewCount": "{{ product.metafields.reviews.rating_count.value }}",
        "worstRating": "{{ product.metafields.reviews.rating.value.scale_min }}",
        "bestRating": "{{ product.metafields.reviews.rating.value.scale_max }}"
      },
    {%- endif -%}
    "brand": {
      "@type": "Brand",
      {%- # In case of a single brand store, this could be hardcoded. Otherwise validate if the product.vendor is the source for the brand name -%}
      "name": {{ product.vendor | json }}
    },
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | json }},
    "category": {{ product.type | json }},
    "url": "{{ shop.url }}{{ product.url }}",
    "sku": {{ product.selected_or_first_available_variant.sku | json }},
    "image": {
      "@type": "ImageObject",
      {%- # Is the page_image (featured_image) the correct one or is there another one that can ben used (i.e. a  metafield) -%}
      "url": "https:{{ page_image | image_url: width: 1024 }}",
      "image": "https:{{ page_image | image_url: width: 1024 }}",
      "name": {{ page_image.alt | json }},
      "width": "1024",
      "height": "1024"
    }
  }
</script>
