{%- doc -%}
    Wine Subscription Flow - Step 3: Confirmation
  Displays selected wines summary and customer info, triggers webhook on confirm.
  Accepts:
    - {object} s: Section settings

  @param {object} [s] - Section settings object providing step 3 copy and labels
{%- enddoc -%}

<li class="splide__slide w-full">
    <div class="flex flex-col gap-8 lg:gap-10 max-w-[488px] mx-auto px-4 lg:px-0">
        {%- comment -%} Title {%- endcomment -%}
        <h2 class="font-cormorant text-[30px] leading-[1.3] text-primary text-center">
            {{ s.step3_title | default: 'Bevestig uw inschrijving' }}
        </h2>

        {%- comment -%} Selected Wines Section {%- endcomment -%}
        <div class="space-y-4">
            <h3 class="font-cormorant text-[20px] leading-[1.3] text-primary">
                {{ s.step3_wines_label | default: 'Geselecteerde wijnen:' }}
            </h3>
            <div
                data-wines-list
                class="space-y-4 pb-5 border-b border-gray-200"
            >
                {%- comment -%} Wines will be populated by JavaScript {%- endcomment -%}
                <p class="text-[15px] text-gray-500">Laden...</p>
            </div>
        </div>

        {%- comment -%} Customer Information Section {%- endcomment -%}
        <div class="space-y-4">
            <h3 class="font-cormorant text-[20px] leading-[1.3] text-primary">
                {{
                    s.step3_customer_info_label
                    | default: 'Klantgegevens:'
                }}
            </h3>
            <div
                data-customer-details
                class="space-y-2"
            >
                {%- comment -%} Details will be populated by JavaScript {%- endcomment -%}
                <p class="text-[15px] text-gray-500">Laden...</p>
            </div>
        </div>

        {%- comment -%} Success Message (Hidden by default) {%- endcomment -%}
        <div
            class="hidden text-center py-8"
            data-success-message
        >
            <div class="mb-4">
                <svg
                    class="w-16 h-16 mx-auto text-[#a08735]"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
            <h3 class="font-cormorant text-2xl text-primary mb-2">
                {{ s.step3_success_title | default: 'Bedankt!' }}
            </h3>
            <p class="text-[15px] text-primary leading-[1.3]">
                {{
                    s.step3_success_message
                    | default: 'Uw inschrijving is bevestigd. We nemen binnenkort contact met u op met verdere details.'
                }}
            </p>
        </div>

        {%- comment -%} Error Message (Hidden by default) {%- endcomment -%}
        <div
            class="hidden text-center py-4"
            data-error-message
        >
            <p class="text-red-600 text-sm">
                {{
                    s.step3_error_submit
                    | default: 'Er is een fout opgetreden bij het indienen van uw inschrijving. Probeer het opnieuw.'
                }}
            </p>
        </div>

        {%- comment -%} Navigation Buttons {%- endcomment -%}
        <div
            class="flex justify-between gap-3 lg:gap-10"
            data-confirmation-buttons
        >
            <button
                type="button"
                class="flex-1 lg:w-[240px] h-[46px] flex items-center justify-center border text-sm font-inter transition-colors hover:opacity-80 cursor-pointer"
                style="border-color: var(--color-secondary-background, #000000); color: var(--color-secondary-foreground, #000000);"
                data-prev-step
            >
                {{ s.step3_back_button | default: 'Terug' }}
            </button>
            <button
                type="button"
                class="flex-1 h-[46px] flex items-center justify-center text-sm font-inter transition-colors hover:opacity-90 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                style="background-color: var(--color-primary-background, #06061C); color: var(--color-primary-foreground, #ffffff);"
                data-confirm
            >
                <span data-confirm-text>
                    {{- s.step3_confirm_button | default: 'Bevestig inschrijving' -}}
                </span>
                <span
                    class="hidden"
                    data-confirm-loading
                >
                    <svg
                        class="animate-spin h-5 w-5 text-white"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                    >
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </span>
            </button>
        </div>
    </div>
</li>
