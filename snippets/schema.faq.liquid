<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "url": "{{ page.url }}",
  "mainEntity": [
    {%- for question in category.items.value -%}
        {
        "@type": "Question",
        "name": "{{ question.title.value }}",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ question.description | metafield_text }}"
        }
        }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
