{%- # Preload fonts -%}
{{
    'Inter-Regular.woff2'
    | asset_url
    | preload_tag: as: 'font', type: 'font/woff2', crossorigin: true
-}}

{{
    'CormorantGaramond-Regular.woff2'
    | asset_url
    | preload_tag: as: 'font', type: 'font/woff2', crossorigin: true
-}}

{%- # Define @font-face declarations -%}
<style>
    @font-face {
        font-family: 'Inter';
        font-display: swap;
        font-weight: 300;
        font-style: normal;
        src: url('{{ 'Inter-Light.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Inter';
        font-display: swap;
        font-weight: 400;
        font-style: normal;
        src: url('{{ 'Inter-Regular.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Inter';
        font-display: swap;
        font-weight: 500;
        font-style: normal;
        src: url('{{ 'Inter-Medium.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Inter';
        font-display: swap;
        font-weight: 600;
        font-style: normal;
        src: url('{{ 'Inter-SemiBold.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Inter';
        font-display: swap;
        font-weight: 700;
        font-style: normal;
        src: url('{{ 'Inter-Bold.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Cormorant Garamond';
        font-display: swap;
        font-weight: 300;
        font-style: normal;
        src: url('{{ 'CormorantGaramond-Light.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Cormorant Garamond';
        font-display: swap;
        font-weight: 400;
        font-style: normal;
        src: url('{{ 'CormorantGaramond-Regular.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Cormorant Garamond';
        font-display: swap;
        font-weight: 500;
        font-style: normal;
        src: url('{{ 'CormorantGaramond-Medium.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Cormorant Garamond';
        font-display: swap;
        font-weight: 600;
        font-style: normal;
        src: url('{{ 'CormorantGaramond-SemiBold.woff2' | asset_url }}') format('woff2');
    }

    @font-face {
        font-family: 'Cormorant Garamond';
        font-display: swap;
        font-weight: 700;
        font-style: normal;
        src: url('{{ 'CormorantGaramond-Bold.woff2' | asset_url }}') format('woff2');
    }
</style>
